{
  "name": "tiposaurus-rex",
  "version": "1.0.0",
  "description": "Gerador de tipos TypeScript para consultas SQL",
  "license": "MIT",
  "author": "Edson Cabral Junior <e2cabraljunior@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tiposaurus": "dist/index.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "smoke:cli": "node dist/index.js --help",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build && npm run smoke:cli",
    "prepare": "npm run build",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "typescript",
    "sql",
    "mysql",
    "code-generator",
    "types",
    "orm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/e2cabral/tiposaurus-rex.git"
  },
  "bugs": {
    "url": "https://github.com/e2cabral/tiposaurus-rex/issues"
  },
  "homepage": "https://github.com/e2cabral/tiposaurus-rex#readme",
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "figlet": "^1.11.0",
    "glob": "^10.5.0",
    "handlebars": "^4.7.9",
    "inquirer": "^12.11.1",
    "inversify": "^7.11.0",
    "mysql2": "^3.22.3",
    "ora": "^8.2.0",
    "prettier": "^3.8.3",
    "reflect-metadata": "^0.2.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/figlet": "^1.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.19",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vitepress": "^1.6.4",
    "vue": "^3.5.34"
  }
}
